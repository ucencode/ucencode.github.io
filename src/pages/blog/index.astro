---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.tsx';
import BlogCard from '../../components/BlogCard.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog — Ahmad Husein Hambali"
  description="Thoughts on backend engineering, Node.js, TypeScript, and building systems that last."
>
  <Header client:load />
  <main class="max-w-5xl mx-auto px-6 py-24 md:py-32">
    <div data-reveal>
      <p class="font-mono text-primary text-sm mb-3 tracking-wide">Blog</p>
      <h1 class="text-2xl md:text-3xl font-bold text-foreground mb-4">
        Thoughts, notes, and dev logs
      </h1>
      <p class="text-muted-foreground max-w-lg mb-12">
        A small collection of things I'm learning, building, breaking, and occasionally overthinking.
      </p>
    </div>

    {posts.length === 0 ? (
      <p class="text-muted-foreground">No posts yet. Check back soon.</p>
    ) : (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post, index) => (
          <BlogCard post={post} index={index} />
        ))}
      </div>
    )}
  </main>
  <Footer />
</BaseLayout>
