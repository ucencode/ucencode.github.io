---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.tsx';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog — Ahmad Husein Hambali"
  description="Thoughts on backend engineering, Node.js, TypeScript, and building systems that last."
>
  <Header client:load />
  <main class="max-w-2xl mx-auto px-6 py-24">
    <div data-reveal>
      <h1 class="text-3xl font-semibold mb-2">Blog</h1>
      <p class="text-muted-foreground mb-12">Thoughts on backend engineering and system design.</p>
    </div>

    {posts.length === 0 ? (
      <p class="text-muted-foreground">No posts yet. Check back soon.</p>
    ) : (
      <ul class="space-y-8">
        {posts.map((post) => (
          <li data-reveal>
            <a href={`/blog/${post.slug}`} class="group block">
              <time class="text-xs font-mono text-muted-foreground">
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h2 class="mt-1 text-lg font-medium group-hover:text-primary transition-colors">
                {post.data.title}
              </h2>
              <p class="mt-1 text-sm text-muted-foreground">{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="mt-2 flex flex-wrap gap-1.5">
                  {post.data.tags.map((tag) => (
                    <span class="tech-tag">{tag}</span>
                  ))}
                </div>
              )}
            </a>
          </li>
        ))}
      </ul>
    )}
  </main>
  <Footer />
</BaseLayout>
