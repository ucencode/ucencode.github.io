---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<section id="blog" class="py-24 md:py-32">
  <div class="max-w-5xl mx-auto px-6">
    <div data-reveal>
      <p class="font-mono text-primary text-sm mb-3 tracking-wide">Blog</p>
      <h2 class="text-2xl md:text-3xl font-bold text-foreground mb-4">
        Thoughts, notes, and dev logs
      </h2>
      <p class="text-muted-foreground max-w-lg mb-12">
        A small collection of things I'm learning, building, breaking, and occasionally overthinking.
      </p>
    </div>

    {posts.length === 0 ? (
      <p class="text-muted-foreground">No posts yet. Check back soon.</p>
    ) : (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
        {posts.map((post, index) => (
          <a
            href={`/blog/${post.slug}`}
            data-reveal
            data-reveal-delay={String(index * 80)}
            class="group flex flex-col gap-3 p-6 rounded-xl border border-border bg-card hover:border-primary/40 transition-colors duration-200"
          >
            <div class="flex items-center gap-3">
              <time class="font-mono text-xs text-muted-foreground">
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
              {post.data.tags[0] && (
                <span class="tech-tag">{post.data.tags[0]}</span>
              )}
            </div>

            <h3 class="text-base font-semibold text-foreground group-hover:text-primary transition-colors leading-snug">
              {post.data.title}
            </h3>

            <p class="text-sm text-muted-foreground leading-relaxed flex-1">
              {post.data.description}
            </p>

            <span class="text-sm text-primary font-medium mt-1">
              Read more →
            </span>
          </a>
        ))}
      </div>
    )}

    <div data-reveal class="flex justify-center">
      <a
        href="/blog"
        class="px-6 py-2.5 rounded-lg border border-border text-sm text-muted-foreground hover:text-foreground hover:border-primary/40 transition-colors duration-200"
      >
        Show more posts
      </a>
    </div>
  </div>
</section>
