---
import { experience, experienceSummary } from '@/data/experience';
---
<section id="experience" class="py-24 md:py-32 section-alt">
  <div class="max-w-5xl mx-auto px-6">
    <div data-reveal>
      <p class="font-mono text-primary text-sm mb-3 tracking-wide">Experience</p>
      <h2 class="text-2xl md:text-3xl font-bold text-foreground mb-4">
        {experienceSummary.title}
      </h2>
      <p class="text-muted-foreground max-w-lg mb-12">
        {experienceSummary.subtitle}
      </p>
    </div>

    <div class="grid lg:grid-cols-[1.4fr,0.6fr] gap-10 lg:gap-14">
      <div class="relative pl-10 border-l border-border/60 space-y-10">
        {experience.map((item, index) => (
          <div data-reveal data-reveal-delay={String(index * 90)}>
            <div class="relative">
              <span class="absolute -left-[24px] top-0.5 w-3 h-3 rounded-full bg-primary ring-4 ring-background"></span>
              <p class="font-mono text-xs text-primary mb-2 tracking-wide">{item.year}</p>
              <h3 class="text-base md:text-lg font-semibold text-foreground">{item.position}</h3>
              <p class="text-sm text-muted-foreground">{item.company}</p>
              <p class="text-xs text-muted-foreground/70 mb-3">{item.location}</p>
              <ul class="space-y-2 text-sm text-muted-foreground leading-relaxed">
                {item.bullets.map((bullet) => (
                  <li class="flex items-start gap-3">
                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary/70 shrink-0"></span>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>

      <div class="space-y-6">
        <div data-reveal data-reveal-delay="150">
          <div class="rounded-lg border border-border bg-card p-6">
            <p class="font-mono text-xs text-primary mb-2 tracking-wide">Highlights</p>
            <h3 class="text-base font-semibold text-foreground mb-3">{experienceSummary.subtitle}</h3>
            <ul class="space-y-2 text-sm text-muted-foreground leading-relaxed">
              {experienceSummary.points.map((point) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary/70 shrink-0"></span>
                  <span>{point}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div data-reveal data-reveal-delay="220">
          <div class="rounded-lg border border-border/60 bg-gradient-to-br from-secondary to-muted p-6">
            <p class="text-xs text-muted-foreground leading-relaxed">{experienceSummary.note}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
